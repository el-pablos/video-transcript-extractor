# ─── Redis Configuration ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password_here
REDIS_CACHE_TTL=604800

# ─── Whisper Configuration (opsional) ───────────────────────────────
WHISPER_MODEL=base
WHISPER_LANGUAGE=auto

# ─── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
